{
  "name": "vn-land-editor",
  "version": "1.0.0",
  "description": "VN-LandEditor - Ứng dụng biên tập thửa đất hệ tọa độ VN-2000",
  "main": "src/main/main.js",
  "scripts": {
    "start": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "preview": "vite preview"
  },
  "keywords": [
    "electron",
    "gis",
    "vn2000",
    "cadastral",
    "ocr"
  ],
  "author": "VN-LandEditor Team",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^32.3.3",
    "electron-builder": "^25.0.5",
    "vite": "^5.4.6",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "fabric": "^5.3.0",
    "proj4": "^2.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "^5.1.0"
  },
  "build": {
    "appId": "com.vnlandeditor.app",
    "productName": "VN-LandEditor",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
